# Copy this file to .env and fill in real values.
#   cp .env.example .env
#
# .env is gitignored. This file is committed so anyone cloning the repo
# knows what needs setting. Never put real secrets in THIS file.

# --- Required in production --------------------------------------------------
# Generate each with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-before-deploying
JWT_SECRET_KEY=change-me-before-deploying-too

# The shared code that gates /api/auth/admin-register — the only public route
# that can create a privileged account. Treat it like a password.
ADMIN_INVITE_CODE=change-me

# --- Database ----------------------------------------------------------------
# Development defaults to SQLite and needs nothing here.
# Production example:
# DATABASE_URL=postgresql://user:password@localhost:5432/dearbaby
DATABASE_URL=sqlite:///dearbaby.db

# --- Tokens ------------------------------------------------------------------
JWT_MINUTES=30
JWT_REFRESH_DAYS=30

# --- CORS --------------------------------------------------------------------
# Comma-separated list of origins allowed to call the API.
CORS_ORIGINS=http://localhost:5173

# --- Stripe (integration point — not wired yet) ------------------------------
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
